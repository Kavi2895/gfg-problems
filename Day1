class Solution {
    public int getSecondLargest(int[] arr) {
        int max=arr[0];
        int max2=Integer.MIN_VALUE;
        for(int i=0;i<arr.length;i++){
            if(max<arr[i]){
                max=arr[i];
            }
        }
        for(int i=0;i<arr.length;i++){
            if(max2<arr[i] && arr[i]!=max){
                max2=arr[i];
            }
        }
        if(max2==Integer.MIN_VALUE){
           return -1;
        }
        return max2;
        
    }
}
